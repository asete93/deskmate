# ── 인증 (실 Claude Code 제어 시 셋 중 하나) ──────────────────
# 1) API 키 (console.anthropic.com):
ANTHROPIC_API_KEY=

# 2) Claude Pro/Max 구독 OAuth 토큰 — 호스트에서 `claude setup-token` 실행 후 붙여넣기.
#    구독 사용량으로 과금, API 크레딧 불필요.
CLAUDE_CODE_OAUTH_TOKEN=

# 3) 위 둘 다 비워두고, Claude Code가 이미 로그인된 호스트에서 직접 실행하면
#    ambient 인증(~/.claude)을 그대로 사용. 이 경우 AGENT_DRIVER=sdk 로 명시.

# mock | sdk | auto (기본 auto: 위 인증 있으면 sdk, 없으면 mock)
AGENT_DRIVER=auto

# ── 서비스 ────────────────────────────────────────────────
SERVICE_NAME=Claude Control
PORT=3200
DATA_DIR=./data

# SMTP URL 설정 시 이메일 알림 실발송 (미설정 시 스텁 로그)
SMTP_URL=


COMPOSE_FILE=docker-compose.yml:docker-compose.subscription.yml