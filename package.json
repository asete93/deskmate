{
  "name": "deskmate",
  "version": "1.0.0",
  "type": "module",
  "description": "Deskmate — Claude Code 멀티 에이전트 팀 오케스트레이션 대시보드",
  "bin": {
    "deskmate": "bin/claude-control.js",
    "claude-control": "bin/claude-control.js"
  },
  "files": [
    "bin",
    "server/src",
    "web/index.html",
    "web/dist",
    "README.md",
    "ARCHITECTURE.md"
  ],
  "engines": {
    "node": ">=22.5"
  },
  "scripts": {
    "build:web": "esbuild web/src/main.jsx --bundle --loader:.css=text --format=iife --jsx-factory=h --jsx-fragment=Fragment --outfile=web/dist/app.js --minify",
    "dev:web": "esbuild web/src/main.jsx --bundle --loader:.css=text --format=iife --jsx-factory=h --jsx-fragment=Fragment --outfile=web/dist/app.js --watch",
    "start": "node server/src/index.js",
    "test": "node --test server/test/",
    "prepack": "npm run build:web"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.209",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.7.1",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "multer": "^2.2.0",
    "node-pty": "^1.1.0",
    "pptxgenjs": "^4.0.1",
    "ws": "^8.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "marked": "^18.0.6",
    "preact": "^10.25.0"
  }
}
